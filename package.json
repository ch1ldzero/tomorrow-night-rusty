{
    "name": "tomorrow-night-rusty",
    "displayName": "Tomorrow Night Rusty",
    "publisher": "n3tw4lk3r",
    "description": "A dark VS Code theme inspired by the Rust documentation color palette and rusty.nvim",
    "version": "3.0.0",
    "icon": "assets/images/icon.png",
    "license": "MIT",

    "engines": {
        "vscode": "^1.70.0"
    },

    "categories": [
        "Themes"
    ],

    "keywords": [
        "theme",
        "dark theme",
        "vscode theme",
        "syntax highlighting",
        "semantic highlighting",
        "rust",
        "rust theme",
        "minimal",
        "cpp",
        "c",
        "go",
        "python",
        "typescript"
    ],

    "repository": {
        "type": "git",
        "url": "https://github.com/ch1ldzero/tomorrow-night-rusty"
    },

    "homepage": "https://github.com/ch1ldzero/tomorrow-night-rusty",

    "bugs": {
        "url": "https://github.com/ch1ldzero/tomorrow-night-rusty/issues"
    },

    "qna": "https://github.com/ch1ldzero/tomorrow-night-rusty/issues",

    "galleryBanner": {
        "color": "#17191b",
        "theme": "dark"
    },

    "extensionKind": ["ui"],

    "scripts": {
        "build": "node scripts/build.js",
        "prepublish": "npm run build"
    },

    "contributes": {
        "themes": [
            {
                "label": "Tomorrow Night Rusty",
                "uiTheme": "vs-dark",
                "path": "./themes/tomorrow-night-rusty.json"
            }
        ]
    }
}

