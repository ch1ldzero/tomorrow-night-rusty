{
  "name": "Tomorrow Night Rusty",
  "type": "dark",
  "colors": {
    "editor.background": "#1E1F21",
    "editor.foreground": "#C5C8C6",
    "editor.lineHighlightBackground": "#373B4180",
    "editorLineNumber.foreground": "#63666E",
    "editorLineNumber.activeForeground": "#FFFFFF",
    "editorCursor.foreground": "#8ABEB7",
    "editor.selectionBackground": "#373B41C0",
    "editor.inactiveSelectionBackground": "#282A2E50",
    "editorIndentGuide.activeBackground": "#F0C67480",
    "editorIndentGuide.background": "#373B41",
    "editorWhitespace.foreground": "#4D5057",
    "editorBracketMatch.background": "#81A2BE40",
    "editorBracketMatch.border": "#81A2BE2E",
    "editorError.foreground": "#C66",
    "editorWarning.foreground": "#F0C674",
    "editorInfo.foreground": "#81A2BE",
    "editorGutter.background": "#1E1F21",
    "sideBar.background": "#17181A",
    "sideBar.foreground": "#C5C8C6",
    "statusBar.background": "#17181A",
    "tab.activeBackground": "#1C1D1F",
    "tab.inactiveBackground": "#17181A",
    "terminal.background": "#1E1F21",
    "terminal.foreground": "#C5C8C6",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#FF9DA4",
    "terminal.ansiGreen": "#B5BD68",
    "terminal.ansiYellow": "#F0C674",
    "terminal.ansiBlue": "#81A2BE",
    "terminal.ansiMagenta": "#B294BB",
    "terminal.ansiCyan": "#8ABEB7",
    "terminal.ansiWhite": "#CCCCCC",
    "terminal.ansiBrightBlack": "#FFFFFF40",
    "terminal.ansiBrightRed": "#FF5B69",
    "terminal.ansiBrightGreen": "#AAB257",
    "terminal.ansiBrightYellow": "#EAB85B",
    "terminal.ansiBrightBlue": "#7094B2",
    "terminal.ansiBrightMagenta": "#A383AD",
    "terminal.ansiBrightCyan": "#7BB2AA",
    "terminal.ansiBrightWhite": "#F2F2F2"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#969896" }
    },

    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#B5BD68" }
    },

    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": { "foreground": "#DE935F" }
    },

    {
      "scope": ["variable", "variable.other.readwrite"],
      "settings": { "foreground": "#C5C8C6" }
    },

    {
      "scope": [
        "variable.parameter",
        "variable.parameter.function",
        "meta.parameter"
      ],
      "settings": { "foreground": "#81A2BE" }
    },

    {
      "scope": [
        "variable.other.property",
        "variable.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": { "foreground": "#DE935F" }
    },

    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": { "foreground": "#85B7B1" }
    },

    {
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.struct",
        "entity.name.type.enum",
        "support.type",
        "support.class",
        "storage.type",
        "meta.type.identifier",
        "meta.return.type",
        "meta.class.identifier",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#DE935F" }
    },

    {
      "scope": [
        "meta.generic",
        "meta.generic-name",
        "meta.template.argument",
        "meta.type.parameters"
      ],
      "settings": { "foreground": "#F0C674" }
    },

    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "keyword.declaration",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.exception",
        "keyword.return"
      ],
      "settings": { "foreground": "#B294BB" }
    },

    {
      "scope": [
        "storage.modifier",
        "storage.type",
        "storage.class",
        "storage.function"
      ],
      "settings": { "foreground": "#B294BB" }
    },

    {
      "scope": ["entity.name.tag", "meta.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#92B2CA" }
    },

    {
      "scope": ["attribute.name", "entity.other.attribute-name"],
      "settings": { "foreground": "#F0C674" }
    },

    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#C5C8C6" }
    }
  ]
}
